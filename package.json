{
  "name": "webxdc-code-playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:pwa": "vite --config pwa.vite.config.ts",
    "build:pwa": "vite build --config pwa.vite.config.ts",
    "preview:pwa": "vite preview --config pwa.vite.config.ts",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json && prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tsconfig/svelte": "^5.0.5",
